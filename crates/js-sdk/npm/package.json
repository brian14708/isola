{
  "name": "isola-core",
  "version": "0.4.0",
  "description": "Node.js SDK for Isola sandboxed code execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "napi": {
    "binaryName": "isola",
    "npmClient": "npm",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "pnpm run tsc && napi build --release --platform --js isola.js --manifest-path ../Cargo.toml --output-dir dist",
    "lint": "biome check src tests && tsc --noEmit -p tsconfig.json",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@napi-rs/cli": "^3.5.1",
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.33.0",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/brian14708/isola"
  }
}
