{
  "name": "isola-core",
  "version": "0.3.0",
  "description": "Node.js SDK for Isola sandboxed code execution",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "napi": {
    "binaryName": "isola",
    "npmClient": "npm",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin"
    ]
  },
  "scripts": {
    "build": "pnpm run tsc && napi build --release --platform --js isola.js --manifest-path ../Cargo.toml --output-dir dist",
    "lint": "biome check src tests && tsc --noEmit -p tsconfig.json",
    "tsc": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@napi-rs/cli": "^3",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0",
    "vitest": "^4.0.0"
  },
  "packageManager": "pnpm@10.32.1",
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/brian14708/isola"
  }
}
